<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#7B1FA2"
                android:startColor="#1A0A2E" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="2dp"
                android:color="#CE93D8" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
