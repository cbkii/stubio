<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer for the adaptive launcher icon (ic_launcher).
    Sourced from artwork/launcher/stubio-icon.svg.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="787"
    android:viewportHeight="787">

    <!-- Top triangle shell -->
    <path
        android:fillColor="@color/stubio_logo_lilac"
        android:pathData="@string/stubio_logo_path_top_triangle" />

    <!-- Bottom triangle shell -->
    <path
        android:fillColor="@color/stubio_logo_blue"
        android:pathData="@string/stubio_logo_path_bottom_triangle" />

    <!-- YouTube player dot -->
    <path
        android:fillColor="@color/stubio_logo_red"
        android:pathData="@string/stubio_logo_path_yt_dot" />

    <!-- Play symbol -->
    <path
        android:fillColor="@color/stubio_logo_white"
        android:pathData="@string/stubio_logo_path_play_button" />

    <!-- Video player dot -->
    <path
        android:fillColor="@color/stubio_logo_yellow"
        android:pathData="@string/stubio_logo_path_vid_dot" />

</vector>
