<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer for the adaptive launcher icon (ic_launcher).
    Converted from the app SVG (787×787 viewBox).

    Layout:
      • Two triangles form a diamond: upper (#9D56BC purple), lower (#3D4793 indigo)
      • Red circle (#C82E48) in the upper half — acts as a play-head indicator
      • White play-triangle pointing right — the media-routing arrow
      • Yellow circle (#FCBC2F) in the lower half — destination/output indicator
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="787"
    android:viewportHeight="787">

    <!-- Upper triangle (purple) -->
    <path
        android:fillColor="#9D56BC"
        android:pathData="M390,27 L20,394 L760,394 Z" />

    <!-- Lower triangle (indigo) -->
    <path
        android:fillColor="#3D4793"
        android:pathData="M20,394 L390,764 L760,394 Z" />

    <!-- Red circle  cx=390.5  cy=194.5  r=55 -->
    <path
        android:fillColor="#C82E48"
        android:pathData="M335.5,194.5 A55,55 0 1,0 445.5,194.5 A55,55 0 1,0 335.5,194.5 Z" />

    <!-- White play triangle  (313,255) → (534,396) → (313,542) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M313,255 L534,396 L313,542 Z" />

    <!-- Yellow circle  cx=389.5  cy=598  r=53.5 -->
    <path
        android:fillColor="#FCBC2F"
        android:pathData="M336,598 A53.5,53.5 0 1,0 443,598 A53.5,53.5 0 1,0 336,598 Z" />

</vector>

