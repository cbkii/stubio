<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state: brighter purple border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#3D2060" />
            <stroke android:width="2dp" android:color="#CE93D8" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2D1B4E" />
            <stroke android:width="1dp" android:color="#6A1B9A" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
