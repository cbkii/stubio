<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/purple_bg_deep"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="32dp"
        android:paddingTop="40dp"
        android:paddingRight="32dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textColor="@color/purple_accent"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="32dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/purple_divider"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_streams"
            android:textColor="@color/purple_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/info_streams"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_primary_player"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/editStreamPrimary"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="@string/hint_stream_primary"
                android:textSize="15sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"
                android:imeOptions="actionNext"
                android:focusable="true"
                android:nextFocusDown="@+id/editStreamFallback"
                android:layout_marginRight="12dp" />

            <ImageButton
                android:id="@+id/btnPickStreamPrimary"
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:background="@drawable/picker_button_bg"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="@string/btn_pick_app"
                android:tint="@color/text_primary"
                android:focusable="true"
                android:nextFocusDown="@+id/btnPickStreamFallback" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_fallback_player"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <EditText
                android:id="@+id/editStreamFallback"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="@string/hint_stream_fallback"
                android:textSize="15sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"
                android:imeOptions="actionNext"
                android:focusable="true"
                android:nextFocusDown="@+id/editTrailerPrimary"
                android:layout_marginRight="12dp" />

            <ImageButton
                android:id="@+id/btnPickStreamFallback"
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:background="@drawable/picker_button_bg"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="@string/btn_pick_app"
                android:tint="@color/text_primary"
                android:focusable="true"
                android:nextFocusDown="@+id/btnPickTrailerPrimary" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/purple_divider"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_trailers"
            android:textColor="@color/purple_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/info_trailers"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_primary_player"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/editTrailerPrimary"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="@string/hint_trailer_primary"
                android:textSize="15sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"
                android:imeOptions="actionNext"
                android:focusable="true"
                android:nextFocusDown="@+id/editTrailerFallback"
                android:layout_marginRight="12dp" />

            <ImageButton
                android:id="@+id/btnPickTrailerPrimary"
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:background="@drawable/picker_button_bg"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="@string/btn_pick_app"
                android:tint="@color/text_primary"
                android:focusable="true"
                android:nextFocusDown="@+id/btnPickTrailerFallback" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_fallback_player"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:layout_marginBottom="36dp">

            <EditText
                android:id="@+id/editTrailerFallback"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="@string/hint_trailer_fallback"
                android:textSize="15sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:focusable="true"
                android:nextFocusDown="@+id/btnSave"
                android:layout_marginRight="12dp" />

            <ImageButton
                android:id="@+id/btnPickTrailerFallback"
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:background="@drawable/picker_button_bg"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="@string/btn_pick_app"
                android:tint="@color/text_primary"
                android:focusable="true"
                android:nextFocusDown="@+id/btnSave" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_save"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:background="@drawable/btn_save_bg"
            android:focusable="true"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
