<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/setupScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/purple_bg_deep"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="48dp"
        android:paddingTop="20dp"
        android:paddingEnd="48dp"
        android:paddingBottom="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_launcher_foreground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setup_title"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:maxWidth="900dp"
            android:text="@string/setup_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <!-- Two-column body: Streams (left) | Trailers (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <!-- Left column: Streams -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_streams"
                    android:textColor="@color/purple_accent"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/info_streams"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp" />

                <include layout="@layout/view_player_row_stream_primary" />
                <include layout="@layout/view_player_row_stream_fallback" />

            </LinearLayout>

            <!-- Vertical divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="20dp"
                android:background="@color/purple_divider" />

            <!-- Right column: Trailers -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_trailers"
                    android:textColor="@color/purple_accent"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/info_trailers"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp" />

                <include layout="@layout/view_player_row_trailer_primary" />
                <include layout="@layout/view_player_row_trailer_fallback" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/label_additional_allowed_hosts"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:maxWidth="900dp"
            android:text="@string/info_additional_allowed_hosts"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/editAdditionalAllowedHosts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/hint_additional_allowed_hosts"
            android:importantForAutofill="no"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:nextFocusDown="@id/btnAdvancedRoutingToggle"
            android:nextFocusUp="@id/editTrailerFallback"
            android:paddingHorizontal="16dp"
            android:scrollHorizontally="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnAdvancedRoutingToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="48dp"
            android:text="@string/advanced_routing_collapsed"
            android:textAllCaps="false"
            android:background="@drawable/btn_save_bg"
            android:textColor="@color/text_primary"
            android:focusable="true"
            android:nextFocusUp="@id/editAdditionalAllowedHosts"
            android:nextFocusDown="@id/checkAdvancedRoutingEnabled" />

        <LinearLayout
            android:id="@+id/advancedRoutingContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/textAdvancedRoutingInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/info_advanced_routing"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <CheckBox
                android:id="@+id/checkAdvancedRoutingEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/label_advanced_routing_enabled"
                android:textColor="@color/text_primary"
                android:focusable="true"
                android:nextFocusUp="@id/btnAdvancedRoutingToggle"
                android:nextFocusDown="@id/editAdvancedRoutingRules" />

            <EditText
                android:id="@+id/editAdvancedRoutingRules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="4"
                android:maxLines="8"
                android:gravity="top|start"
                android:inputType="textMultiLine|textNoSuggestions"
                android:hint="@string/hint_advanced_routing_rules"
                android:background="@drawable/edit_text_bg"
                android:padding="8dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:layout_marginTop="8dp"
                android:nextFocusUp="@id/checkAdvancedRoutingEnabled"
                android:nextFocusDown="@id/btnPickAdvancedRoutingApp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnPickAdvancedRoutingApp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:text="@string/btn_pick_advanced_routing_app"
                    android:textAllCaps="false"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/btn_save_bg"
                    android:textColor="@color/text_primary"
                    android:nextFocusUp="@id/editAdvancedRoutingRules"
                    android:nextFocusDown="@id/btnSave"
                    android:nextFocusRight="@id/btnValidateAdvancedRouting" />

                <Button
                    android:id="@+id/btnValidateAdvancedRouting"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:text="@string/btn_validate_advanced_routing"
                    android:textAllCaps="false"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/btn_save_bg"
                    android:textColor="@color/text_primary"
                    android:nextFocusUp="@id/editAdvancedRoutingRules"
                    android:nextFocusDown="@id/btnSave"
                    android:nextFocusLeft="@id/btnPickAdvancedRoutingApp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Save button — full width below both columns -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/btn_save_bg"
            android:focusable="true"
            android:nextFocusDown="@id/btnPickStreamPrimary"
            android:nextFocusUp="@id/btnValidateAdvancedRouting"
            android:stateListAnimator="@null"
            android:text="@string/btn_save"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
