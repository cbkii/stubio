<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/setupScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/purple_bg_deep"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="48dp"
        android:paddingTop="28dp"
        android:paddingEnd="48dp"
        android:paddingBottom="28dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp"
            android:maxWidth="900dp"
            android:text="@string/setup_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <!-- Two-column body: Streams (left) | Trailers (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <!-- Left column: Streams -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_streams"
                    android:textColor="@color/purple_accent"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/info_streams"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp" />

                <include layout="@layout/view_player_row_stream_primary" />
                <include layout="@layout/view_player_row_stream_fallback" />

            </LinearLayout>

            <!-- Vertical divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="20dp"
                android:background="@color/purple_divider" />

            <!-- Right column: Trailers -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_trailers"
                    android:textColor="@color/purple_accent"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/info_trailers"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp" />

                <include layout="@layout/view_player_row_trailer_primary" />
                <include layout="@layout/view_player_row_trailer_fallback" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/label_additional_allowed_hosts"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:maxWidth="900dp"
            android:text="@string/info_additional_allowed_hosts"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/editAdditionalAllowedHosts"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:autofillHints=""
            android:background="@drawable/edit_text_bg"
            android:hint="@string/hint_additional_allowed_hosts"
            android:importantForAutofill="no"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:nextFocusDown="@id/btnSave"
            android:paddingHorizontal="16dp"
            android:scrollHorizontally="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="18sp" />

        <!-- Save button — full width below both columns -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/btn_save_bg"
            android:focusable="true"
            android:nextFocusUp="@id/editTrailerFallback"
            android:stateListAnimator="@null"
            android:text="@string/btn_save"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
